# Публичный HTTPS-URL без завершающего слэша (как видит интернет).
# Нужен, чтобы Telegram/VK открывали картинки по URL: {PUBLIC_BASE_URL}/static/images/<файл>
# Локально удобно через ngrok/cloudflared: https://xxxx.ngrok-free.app
PUBLIC_BASE_URL=

# --- Telegram ---
# Токен @BotFather
TELEGRAM_BOT_TOKEN=

# Секрет для setWebhook (заголовок X-Telegram-Bot-Api-Secret-Token). Рекомендуется в проде.
TELEGRAM_WEBHOOK_SECRET=

# Webhook: POST https://<ваш-домен>/telegram/webhook

# --- VK ---
# Токен сообщества с правами на сообщения (Сообщество → Настройки → Работа с API → Ключи доступа)
VK_API_TOKEN=

# ID сообщества (только цифры, без минуса)
VK_GROUP_ID=

# Строка подтверждения Callback API (то, что VK просит вернуть при проверке сервера)
VK_CALLBACK_CONFIRMATION=

# Секретный ключ Callback API (если задан в настройках VK — должен совпадать; иначе оставьте пустым)
VK_SECRET=

# Callback URL: POST https://<ваш-домен>/vk/callback

# Порт наружу (если меняете маппинг в docker-compose)
PORT=8000

# Проверка живости: GET / (и дублирующий GET /healthz, если не перехватывается прокси)
