# Публичный HTTPS-URL без завершающего слэша (как видит интернет).
# Нужен, чтобы Telegram/VK открывали картинки по URL: {PUBLIC_BASE_URL}/static/images/<файл>
# В репозитории лежат PNG-заглушки в static/images; Telegram шлёт их с диска контейнера (без запроса к домену).
# Локально удобно через ngrok/cloudflared: https://xxxx.ngrok-free.app
PUBLIC_BASE_URL=

# --- Telegram ---
# Токен @BotFather
TELEGRAM_BOT_TOKEN=

# Секрет для setWebhook (заголовок X-Telegram-Bot-Api-Secret-Token). Рекомендуется в проде.
# Важно: если переменная задана, Telegram ОБЯЗАН слать тот же secret_token — иначе POST /telegram/webhook → 403.
# setWebhook: ...&secret_token=<то же значение> (или оставьте пустым для отключения проверки).
TELEGRAM_WEBHOOK_SECRET=

# Webhook: POST https://<ваш-домен>/telegram/webhook

# --- VK ---
# Токен сообщества с правами на сообщения (Сообщество → Настройки → Работа с API → Ключи доступа)
VK_API_TOKEN=

# ID сообщества (только цифры, без минуса)
VK_GROUP_ID=

# Строка подтверждения Callback API (то, что VK просит вернуть при проверке сервера)
VK_CALLBACK_CONFIRMATION=

# Секретный ключ Callback API (если задан в настройках VK — должен совпадать; иначе оставьте пустым)
# Несовпадение → 403 на /vk/callback, ВКонтакте не получит «ok» и бот не ответит.
VK_SECRET=

# Callback URL: POST https://<ваш-домен>/vk/callback
#
# Если в логах VK API 912: в сообществе → Управление → Сообщения → «Настройки для бота» → «Возможности ботов» — Включены.
# Без этого ВК не принимает клавиатуру с кнопками; бот при 912 повторит текст без кнопок и примет ответ буквой A/B/C.
# Тексты в ВК: плоский message + format_data (JSON, UTF-16 offsets), см. messages.send в API 5.199+.
#
# VK Mini App (как в примере vk.com/app…): в настройках приложения укажите URL страницы
#   https://<ваш-домен>/vk/miniapp
# (тот же домен, что и для Callback API). Страница: static/vk_miniapp/index.html — кнопка открывает чат с сообществом (sel=-<VK_GROUP_ID>).

# Порт наружу (если меняете маппинг в docker-compose)
PORT=8000

# Проверка живости: GET / (и дублирующий GET /healthz, если не перехватывается прокси)
